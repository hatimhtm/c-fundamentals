# Doxyfile — minimal config for c-fundamentals
# Run: `doxygen Doxyfile` → output lands in docs/html

PROJECT_NAME           = "C Fundamentals"
PROJECT_BRIEF          = "Algorithms · data structures · cryptography · systems — pure C11, zero deps"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = YES
FULL_PATH_NAMES        = NO
TAB_SIZE               = 2
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 4
AUTOLINK_SUPPORT       = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = SYSTEM
SHOW_INCLUDE_FILES     = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

INPUT                  = .
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.c *.h *.md
RECURSIVE              = YES
EXCLUDE                = build docs assets .github tests
EXCLUDE_PATTERNS       = */build/* */docs/*
USE_MDFILE_AS_MAINPAGE = README.md

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
SOURCE_TOOLTIPS        = YES

ALPHABETICAL_INDEX     = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_DYNAMIC_MENUS     = YES
HTML_INDEX_NUM_ENTRIES = 100
DISABLE_INDEX          = NO
GENERATE_TREEVIEW      = YES
ENUM_VALUES_PER_LINE   = 4

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
SEARCH_INCLUDES        = YES
PREDEFINED             = __APPLE__

CLASS_DIAGRAMS         = NO
HAVE_DOT               = NO

QUIET                  = YES
